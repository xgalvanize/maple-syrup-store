# Helm secrets file - Copy to helm-chart/secrets.yaml and fill in values
# DO NOT COMMIT THIS FILE

backend:
  secrets:
    DB_PASSWORD: "CHANGE_ME_DATABASE_PASSWORD"
    SECRET_KEY: "CHANGE_ME_DJANGO_SECRET_KEY"
    EMAIL_HOST_USER: "your-email@gmail.com"
    EMAIL_HOST_PASSWORD: "your-app-password-here"
    ADMIN_EMAIL: "admin@maplesyrup.co"
  
  # Security settings (production)
  env:
    # HTTPS/SSL (enable in production with proper certificates)
    SECURE_SSL_REDIRECT: "false"
    SESSION_COOKIE_SECURE: "false"
    CSRF_COOKIE_SECURE: "false"
    
    # HSTS (enable in production)
    SECURE_HSTS_SECONDS: "0"
    SECURE_HSTS_INCLUDE_SUBDOMAINS: "true"
    SECURE_HSTS_PRELOAD: "true"
    
    # Rate limiting
    RATELIMIT_ENABLE: "true"

postgres:
  secrets:
    POSTGRES_PASSWORD: "CHANGE_ME_DATABASE_PASSWORD"

# Django superuser credentials (for seed script)
django:
  superuser:
    username: "farmer"
    email: "farmer@maplesyrup.co"
    password: "CHANGE_ME_SUPERUSER_PASSWORD"
